# Dependencies
node_modules/

# Environment variables (contains real credentials — do not commit)
backend/.env

# User-uploaded files (auto-created by server at runtime)
backend/uploads/

# Temp files from mongodb-memory-server (used during tests)
backend/.tmp/

# Playwright test artifacts
backend/playwright-report/
backend/test-results/

# Jest coverage output (auto-generated)
backend/coverage/

# OS files
.DS_Store
Thumbs.db

# Word temporary lock files
~$*.docx
